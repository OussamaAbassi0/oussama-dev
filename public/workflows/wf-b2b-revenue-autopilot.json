      "parameters": {
        "content": "## Étape 7 — Tracking & Follow-up\nSuivi des ouvertures/clics via Webhook + planification automatique des relances J+3, J+7, J+14",
        "height": 180,
        "width": 360
      },
      "id": "note-07",
      "name": "Note — Follow-up",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [4300, 180]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "email-events",
        "responseMode": "onReceived",
        "responseData": "noData"
      },
      "id": "b2b-023",
      "name": "Webhook — Email Events SendGrid",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [4320, 400]
    },
    {
      "parameters": {
        "jsCode": "const events = $input.all();\nconst opens = events.filter(e => e.json.event === 'open');\nconst clicks = events.filter(e => e.json.event === 'click');\nconst bounces = events.filter(e => e.json.event === 'bounce');\nconst unsubscribes = events.filter(e => e.json.event === 'unsubscribe');\n\nreturn [{ json: {\n  total_events: events.length,\n  opens: opens.length,\n  clicks: clicks.length,\n  bounces: bounces.length,\n  unsubscribes: unsubscribes.length,\n  open_rate: events.length > 0 ? Math.round(opens.length / events.length * 100) : 0,\n  click_rate: opens.length > 0 ? Math.round(clicks.length / opens.length * 100) : 0,\n  processed_at: new Date().toISOString()\n}}];"
      },
      "id": "b2b-024",
      "name": "Code — Agréger Métriques Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
