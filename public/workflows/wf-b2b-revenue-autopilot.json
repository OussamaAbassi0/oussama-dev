      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [240, 400]
    },
    {
      "parameters": {
        "content": "## Étape 1 — Recherche de prospects ICP\nAppel Apollo.io pour récupérer des leads qualifiés (CEO/CTO/Founder, 11-1000 employés, France/Belgique/Suisse/Canada)",
        "height": 180,
        "width": 340
      },
      "id": "note-01",
      "name": "Note — Prospection ICP",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [420, 220]
    },
    {
      "parameters": {
        "url": "https://api.apollo.io/v1/mixed_people/search",
        "method": "POST"
      },
      "id": "b2b-002",
      "name": "HTTP — Apollo Fetch ICP Leads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [460, 400]
    },
    {
      "parameters": {
        "jsCode": "const leads = $input.first().json.people || [];\nconsole.log('[Apollo] ' + leads.length + ' leads fetched');\nreturn leads.map(p => ({ json: {\n  apollo_id: p.id || 'unknown',\n  first_name: p.first_name || '',\n  last_name: p.last_name || '',\n  full_name: (p.first_name || '') + ' ' + (p.last_name || ''),\n  email: p.email || '',\n  title: p.title || '',\n  linkedin_url: p.linkedin_url || '',\n  company: p.organization ? p.organization.name : '',\n  company_domain: p.organization ? p.organization.primary_domain : '',\n  company_size: p.organization ? p.organization.num_employees : 0,\n  company_industry: p.organization ? p.organization.industry : '',\n  company_country: p.organization ? p.organization.country : '',\n  seniority: p.seniority || '',\n  fetched_at: new Date().toISOString()\n}}));"
      },
      "id": "b2b-003",
      "name": "Code — Normaliser Leads",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 400]
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "b2b-004",
      "name": "SplitInBatches — 1 Lead à la fois",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 2,
      "position": [900, 400]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{ $json.email }}",
              "operation": "isNotEmpty"
            }
          ]
        }
      },
      "id": "b2b-005",
      "name": "IF — Email valide?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [1120, 400]
    },
    {
      "parameters": {
        "content": "## Étape 2 — Enrichissement LinkedIn\nScraping LinkedIn pour obtenir les dernières activités, publications et signaux d'intention du prospect",
        "height": 180,
        "width": 340
      },
      "id": "note-02",
      "name": "Note — Enrichissement",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [1300, 220]
    },
    {
      "parameters": {
        "url": "https://nubela.co/proxycurl/api/v2/linkedin",
        "method": "GET"
      },
      "id": "b2b-006",
      "name": "HTTP — Proxycurl LinkedIn Profile",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [1340, 340]
    },
    {
      "parameters": {
        "url": "https://nubela.co/proxycurl/api/v2/linkedin/company/job",
        "method": "GET"
      },
      "id": "b2b-007",
      "name": "HTTP — Proxycurl Company Jobs",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [1340, 500]
    },
    {
      "parameters": {
        "jsCode": "const profile = $('HTTP — Proxycurl LinkedIn Profile').first().json;\nconst jobs = $('HTTP — Proxycurl Company Jobs').first().json;\nconst lead = $('IF — Email valide?').first().json;\n\nconst recent_posts = profile.activities ? profile.activities.slice(0, 3).map(a => a.title || '').join(' | ') : '';\nconst headline = profile.headline || '';\nconst summary = profile.summary || '';\nconst company_desc = profile.experiences && profile.experiences[0] ? profile.experiences[0].description || '' : '';\nconst hiring = jobs.job ? true : false;\n\nreturn [{ json: {\n  ...lead,\n  linkedin_headline: headline,\n  linkedin_summary: summary.slice(0, 300),\n  recent_posts: recent_posts,\n  company_description: company_desc.slice(0, 300),\n  is_hiring: hiring,\n  enriched_at: new Date().toISOString()\n}}];"
      },
      "id": "b2b-008",
      "name": "Code — Fusionner Données Enrichies",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1560, 400]
    },
    {
      "parameters": {
        "content": "## Étape 3 — Score IA du prospect\nGPT-4o analyse le profil complet et attribue un score ICP de 0 à 100 + identifie les pain points pertinents",
        "height": 180,
        "width": 340
      },
      "id": "note-03",
      "name": "Note — Scoring IA",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [1760, 220]
    },
    {
      "parameters": {
        "url": "https://api.openai.com/v1/chat/completions",
        "method": "POST"
      },
      "id": "b2b-009",
      "name": "HTTP — GPT-4o Score ICP",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [1800, 400]
    },
    {
      "parameters": {
        "jsCode": "const resp = $input.first().json;\nconst lead = $('Code — Fusionner Données Enrichies').first().json;\n\nlet score = 0;\nlet pain_points = [];\nlet opportunity = '';\nlet icp_tier = 'C';\n\ntry {\n  const content = resp.choices[0].message.content;\n  const parsed = JSON.parse(content);\n  score = parsed.score || 0;\n  pain_points = parsed.pain_points || [];\n  opportunity = parsed.opportunity || '';\n  if (score >= 80) icp_tier = 'A';\n  else if (score >= 60) icp_tier = 'B';\n  else icp_tier = 'C';\n} catch(e) {\n  score = 0;\n  pain_points = ['analyse indisponible'];\n}\n\nreturn [{ json: {\n  ...lead,\n  icp_score: score,\n  icp_tier: icp_tier,\n  pain_points: pain_points,\n  opportunity_summary: opportunity,\n  scored_at: new Date().toISOString()\n}}];"
      },
      "id": "b2b-010",
      "name": "Code — Parser Score ICP",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2020, 400]
    },
    {
      "parameters": {
        "dataType": "number",
        "value1": "={{ $json.icp_score }}",
        "rules": {
          "rules": [
            { "operation": "largerEqual", "value2": 80, "output": 0 },
            { "operation": "largerEqual", "value2": 60, "output": 1 },
            { "operation": "smaller", "value2": 60, "output": 2 }
          ]
        }
      },
      "id": "b2b-011",
      "name": "Switch — Tier A / B / C",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 1,
      "position": [2240, 400]
    },
    {
      "parameters": {
        "content": "## Étape 4 — Rédaction email ultra-personnalisé\nGPT-4o rédige un email cold outreach basé sur les pain points identifiés, les posts LinkedIn récents et le contexte de l'entreprise",
        "height": 200,
        "width": 360
      },
      "id": "note-04",
      "name": "Note — Rédaction Email",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [2460, 180]
    },
    {
      "parameters": {
        "url": "https://api.openai.com/v1/chat/completions",
        "method": "POST"
      },
      "id": "b2b-012",
      "name": "HTTP — GPT-4o Email Tier A",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [2480, 300]
    },
    {
      "parameters": {
        "url": "https://api.openai.com/v1/chat/completions",
        "method": "POST"
      },
      "id": "b2b-013",
      "name": "HTTP — GPT-4o Email Tier B",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [2480, 460]
    },
    {
      "parameters": {
        "values": {
          "string": [
            { "name": "skip_reason", "value": "ICP score too low — under 60" },
            { "name": "icp_tier", "value": "={{ $json.icp_tier }}" },
            { "name": "full_name", "value": "={{ $json.full_name }}" }
          ]
        },
        "options": {}
      },
      "id": "b2b-014",
      "name": "Set — Marquer Skip Tier C",
      "type": "n8n-nodes-base.set",
      "typeVersion": 1,
      "position": [2480, 620]
    },
    {
      "parameters": {
        "jsCode": "const email_resp = $input.first().json;\nconst lead = $('Switch — Tier A / B / C').first().json;\n\nlet subject = '';\nlet body = '';\n\ntry {\n  const content = email_resp.choices[0].message.content;\n  const parsed = JSON.parse(content);\n  subject = parsed.subject || 'Collaboration automation';\n  body = parsed.body || '';\n} catch(e) {\n  subject = 'Automatiser vos processus — ' + (lead.company || '');\n  body = 'Bonjour ' + (lead.first_name || '') + ', ...';\n}\n\nreturn [{ json: {\n  ...lead,\n  email_subject: subject,\n  email_body: body,\n  email_generated_at: new Date().toISOString()\n}}];"
      },
      "id": "b2b-015",
      "name": "Code — Parser Email Généré",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2720, 380]
    },
    {
      "parameters": {
        "content": "## Étape 5 — Vérification anti-spam\nAnalyse du score spam, vérification des règles de conformité RGPD et validation du ton avant envoi",
        "height": 160,
        "width": 320
      },
      "id": "note-05",
      "name": "Note — Anti-Spam",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [2940, 200]
    },
    {
      "parameters": {
        "url": "https://api.openai.com/v1/chat/completions",
        "method": "POST"
      },
      "id": "b2b-016",
      "name": "HTTP — GPT-4o Spam Check",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [2960, 380]
    },
    {
      "parameters": {
        "jsCode": "const check = $input.first().json;\nconst lead = $('Code — Parser Email Généré').first().json;\n\nlet spam_score = 0;\nlet is_compliant = true;\nlet improvements = [];\n\ntry {\n  const content = check.choices[0].message.content;\n  const parsed = JSON.parse(content);\n  spam_score = parsed.spam_score || 0;\n  is_compliant = parsed.is_compliant !== false;\n  improvements = parsed.improvements || [];\n} catch(e) {\n  spam_score = 5;\n}\n\nreturn [{ json: {\n  ...lead,\n  spam_score: spam_score,\n  is_compliant: is_compliant,\n  email_improvements: improvements,\n  ready_to_send: spam_score < 30 && is_compliant\n}}];"
      },
      "id": "b2b-017",
      "name": "Code — Parser Spam Check",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3180, 380]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.ready_to_send }}",
              "value2": true
            }
          ]
        }
      },
      "id": "b2b-018",
      "name": "IF — Prêt à envoyer?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [3400, 380]
    },
