    {
      "parameters": {
        "jsCode": "const raw = $input.first().json.body || '';\n// Normalize: remove extra whitespace, fix common OCR errors\nconst cleaned = raw\n  .replace(/\\s+/g, ' ')\n  .replace(/[|]{1}/g, 'I')\n  .replace(/0(?=[a-zA-Z])/g, 'O')\n  .trim();\n\nreturn [{ json: { \n  raw_text: raw,\n  cleaned_text: cleaned,\n  char_count: cleaned.length,\n  word_count: cleaned.split(' ').length,\n  doc_id: $input.first().json.doc_id\n}}];"
      },
      "id": "a1b2c3d4-0007-4000-8000-000000000007",
      "name": "Code — Clean & Normalize Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1300, 360]
    },
    {
      "parameters": {
        "resource": "text",
        "operation": "message",
        "modelId": { "value": "gpt-4o" },
        "messages": {
          "values": [
            {
              "role": "system",
              "content": "You are a medical document classification expert. Analyze the provided medical document text and classify it into exactly one of these categories:\n- PRESCRIPTION: Drug prescriptions, medication orders\n- LAB_RESULT: Blood tests, urine analysis, culture results, pathology\n- IMAGING_REPORT: X-ray, MRI, CT scan, ultrasound reports\n- REFERRAL: Patient referral letters between practitioners\n- DISCHARGE_SUMMARY: Hospital discharge summaries\n- CONSULTATION_NOTE: Doctor consultation notes\n- UNKNOWN: Cannot be classified\n\nRespond with a JSON object: { \"type\": \"CATEGORY\", \"confidence\": 0.95, \"reason\": \"brief reason\", \"language\": \"fr|en|ar\", \"urgency\": \"ROUTINE|URGENT|STAT\" }"
            },
            {
              "role": "user",
              "content": "Classify this medical document:\n\n{{ $json.cleaned_text }}"
            }
          ]
        },
        "options": { "temperature": 0.1, "maxTokens": 300 }
      },
      "id": "a1b2c3d4-0008-4000-8000-000000000008",
      "name": "GPT-4o — Classify Document Type",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.4,
      "position": [1520, 360]
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json.message.content;\nlet classification;\ntry {\n  const jsonMatch = response.match(/\\{[\\s\\S]*\\}/);\n  classification = JSON.parse(jsonMatch[0]);\n} catch(e) {\n  classification = { type: 'UNKNOWN', confidence: 0, reason: 'Parse error', urgency: 'ROUTINE', language: 'fr' };\n}\nreturn [{ json: { \n  ...($input.first().json),\n  doc_type: classification.type,\n  doc_confidence: classification.confidence,\n  doc_urgency: classification.urgency,\n  doc_language: classification.language,\n  classification_reason: classification.reason\n}}];"
      },
      "id": "a1b2c3d4-0009-4000-8000-000000000009",
      "name": "Code — Parse Classification",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1740, 360]
    },
    {
      "parameters": {
        "rules": {
          "rules": [
            { "outputKey": "prescription", "conditions": { "conditions": [{ "leftValue": "={{ $json.doc_type }}", "rightValue": "PRESCRIPTION", "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputKey": "lab", "conditions": { "conditions": [{ "leftValue": "={{ $json.doc_type }}", "rightValue": "LAB_RESULT", "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputKey": "imaging", "conditions": { "conditions": [{ "leftValue": "={{ $json.doc_type }}", "rightValue": "IMAGING_REPORT", "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputKey": "referral", "conditions": { "conditions": [{ "leftValue": "={{ $json.doc_type }}", "rightValue": "REFERRAL", "operator": { "type": "string", "operation": "equals" } }] } },
            { "outputKey": "other", "conditions": { "conditions": [{ "leftValue": "={{ $json.doc_type }}", "rightValue": "UNKNOWN", "operator": { "type": "string", "operation": "notEquals" } }] } }
          ]
        },
        "options": {}
      },
