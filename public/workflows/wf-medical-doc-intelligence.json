      "id": "a1b2c3d4-0013-4000-8000-000000000013",
      "name": "GPT-4o — Extract Imaging Report",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1.4,
      "position": [2180, 560]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst raw = item.message?.content || '{}';\nlet extracted = {};\ntry {\n  const match = raw.match(/\\{[\\s\\S]*\\}/);\n  extracted = JSON.parse(match[0]);\n} catch(e) { extracted = { extraction_error: true }; }\n\n// Validation rules\nconst errors = [];\nif (!extracted.patient?.full_name) errors.push('MISSING_PATIENT_NAME');\nif (!extracted.prescriber?.full_name && item.doc_type === 'PRESCRIPTION') errors.push('MISSING_PRESCRIBER');\nif (!extracted.prescription_date && item.doc_type === 'PRESCRIPTION') errors.push('MISSING_DATE');\nif (extracted.medications?.length === 0) errors.push('NO_MEDICATIONS_FOUND');\n\nreturn [{ json: {\n  ...item,\n  extracted_data: extracted,\n  validation_errors: errors,\n  is_valid: errors.length === 0,\n  has_critical: (\n    extracted.doc_urgency === 'STAT' || \n    extracted.critical_values?.length > 0 ||\n    extracted.critical_finding === true ||\n    extracted.is_narcotics === true\n  )\n}}];"
      },
